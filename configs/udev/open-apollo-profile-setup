#!/bin/bash
# open-apollo-profile-setup — Auto-configure Apollo audio on hotplug
# Triggered by udev when Apollo PCI device appears.
#
# Uses systemd-run to launch setup in a transient service, fully detached
# from the udev process tree. This survives the PipeWire restart that
# apollo-setup-io triggers internally.

systemd-run --no-block --unit=open-apollo-setup \
    /usr/local/bin/open-apollo-setup-worker
